package mainview

import (
	"fmt"

	"github.com/sookmook/wall-vault/internal/i18n"
)

templ AgentsGrid(clients []*ClientVM) {
	<section>
		<div class="section-head">
			<h3>{ i18n.T("agents") } · { fmt.Sprint(len(clients)) }</h3>
			<button class="btn-add" hx-get="/hx/clients/new" hx-target="#slideover" hx-swap="outerHTML">{ i18n.T("add") }</button>
		</div>
		<div class="grid-cards" data-wv-reorder="agents">
			for _, c := range clients {
				@AgentCard(c)
			}
		</div>
	</section>
}
