package slideover

import (
	"fmt"
	"strings"

	"github.com/sookmook/wall-vault/internal/i18n"
)

templ ServiceEdit(s *ServiceVM) {
	<form data-wv-submit={"/admin/services/" + s.ID} data-wv-method="PUT" class="wv-form">
		<div class="wv-form-section">
			<div class="wv-form-section-title">{ i18n.T("sec_basic") }</div>
			<label class="wv-field">
				<span class="wv-field-label">{ i18n.T("f_name") }</span>
				<input name="name" value={s.Name}/>
			</label>
			if s.IsLocal {
				<label class="wv-field">
					<span class="wv-field-label">{ i18n.T("f_local_url") }</span>
					<input name="local_url" value={s.LocalURL} placeholder={ i18n.T("ph_local_url") }/>
					<small class="hint">{ i18n.T("hint_local_url") }</small>
				</label>
			}
		</div>

		<div class="wv-form-section">
			<div class="wv-form-section-title">{ i18n.T("sec_routing") }</div>
			<label class="wv-field">
				<span class="wv-field-label">{ i18n.T("f_default_model") }</span>
				<div class="wv-field-group">
					<select name="default_model" data-wv-models={s.ID} data-wv-current={s.DefaultModel}>
						if s.DefaultModel != "" {
							<option value={s.DefaultModel} selected>{ s.DefaultModel }</option>
						} else {
							<option value="" selected>{ i18n.T("ph_model_select") }</option>
						}
						for _, m := range s.Models {
							if m != s.DefaultModel {
								<option value={ m }>{ m }</option>
							}
						}
					</select>
					if s.DefaultModel != "" {
						<button type="button" class="btn-mini" data-wv-demote-default title="현재 기본 모델을 허용 목록 끝에 추가하고 기본을 비움">↓ 허용으로</button>
						<button type="button" class="btn-mini btn-danger" data-wv-clear-default title="기본 모델 지움">✕ 지움</button>
					}
				</div>
				<small class="hint">{ i18n.T("hint_default_model") }</small>
				<details class="wv-custom-model">
					<summary>직접 입력 (드롭다운에 원하는 모델이 없을 때)</summary>
					<input name="default_model_custom" placeholder="모델 ID 직접 입력 (저장 시 기본 모델로 적용)"/>
				</details>
			</label>
			<label class="wv-field">
				<span class="wv-field-label">{ i18n.T("f_allowed_models") }</span>
				<textarea name="allowed_models" data-wv-allowed-models placeholder="claude-sonnet-4-5&#10;claude-opus-4-5">{ strings.Join(s.AllowedModels, "\n") }</textarea>
				<small class="hint">{ i18n.T("hint_allowed_models") }</small>
				if len(s.CatalogUnused) > 0 {
					<details class="wv-catalog-picker">
						<summary>{ fmt.Sprintf("카탈로그에서 추가 (%d개)", len(s.CatalogUnused)) }</summary>
						<div class="wv-catalog-filter">
							<input type="search" data-wv-catalog-filter placeholder="모델 ID 필터… (타이핑하면 숨김)"/>
						</div>
						<div class="wv-catalog-list">
							for _, m := range s.CatalogUnused {
								<label class="wv-catalog-item">
									<input type="checkbox" value={m} data-wv-catalog-item/>
									<span>{ m }</span>
								</label>
							}
						</div>
						<div class="wv-catalog-actions">
							<button type="button" class="btn-mini" data-wv-add-catalog>선택 항목 허용 목록에 추가</button>
							<button type="button" class="btn-mini" data-wv-catalog-clear>체크 해제</button>
						</div>
					</details>
				}
			</label>
		</div>

		<div class="wv-form-section">
			<div class="wv-form-section-title">{ i18n.T("sec_advanced") }</div>
			<label class="wv-field">
				<span class="wv-field-label">{ i18n.T("f_sort_order") }</span>
				<input name="sort_order" type="number" value={fmt.Sprint(s.SortOrder)}/>
				<small class="hint">{ i18n.T("hint_sort_order") }</small>
			</label>
			<div class="wv-field">
				<label class="wv-field-inline">
					<input type="checkbox" name="enabled" checked?={s.Enabled}/>
					<span>{ i18n.T("f_enabled") }</span>
				</label>
				<label class="wv-field-inline">
					<input type="checkbox" name="proxy_enabled" checked?={s.ProxyEnabled}/>
					<span>{ i18n.T("f_proxy_enabled") }</span>
				</label>
				<small class="hint">{ i18n.T("hint_proxy_enabled") }</small>
			</div>
		</div>

		<div class="wv-form-actions">
			<button type="button" class="btn-secondary" data-wv-dismiss>{ i18n.T("act_cancel") }</button>
			<button type="submit">{ i18n.T("act_save") }</button>
		</div>
	</form>
}
