package mainview

import (
	"fmt"

	"github.com/sookmook/wall-vault/internal/i18n"
)

templ ServicesGrid(services []*ServiceVM) {
	<section>
		<div class="section-head">
			<h3>{ i18n.T("services") } · { fmt.Sprint(len(services)) }</h3>
		</div>
		<div class="grid-cards">
			for _, s := range services {
				@ServiceCard(s)
			}
		</div>
	</section>
}
