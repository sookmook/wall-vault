package mainview

import "fmt"

templ AgentsGrid(clients []*ClientVM) {
	<section>
		<h3>Agents · { fmt.Sprint(len(clients)) }</h3>
		<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:8px">
			for _, c := range clients {
				@AgentCard(c)
			}
		</div>
	</section>
}
