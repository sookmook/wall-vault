package slideover

import (
	"github.com/sookmook/wall-vault/internal/i18n"
)

// AgentType options shown in the create dropdown.
// Free text is still allowed; the list just makes typical choices one-click.
var agentTypeOptions = []string{
	"openclaw",
	"nanoclaw",
	"claude-code",
	"cline",
	"cursor",
	"cokacdir",
	"gemini-cli",
	"econoworld",
}

templ ClientCreate(services []*ServiceVM, serviceModels map[string]ServiceModelGroup) {
	<form data-wv-submit="/admin/clients" data-wv-method="POST" class="wv-form"
		data-wv-service-models={ serviceModelJSON(serviceModels) }>
		<div class="wv-form-section">
			<div class="wv-form-section-title">{ i18n.T("sec_basic") }</div>
			<label class="wv-field">
				<span class="wv-field-label">{ i18n.T("f_id") }</span>
				<input name="id" required placeholder={ i18n.T("ph_id_example") }/>
			</label>
			<label class="wv-field">
				<span class="wv-field-label">{ i18n.T("f_name") }</span>
				<input name="name" required placeholder={ i18n.T("ph_name_example") }/>
			</label>
			<label class="wv-field">
				<span class="wv-field-label">{ i18n.T("f_agent_type") }</span>
				<select name="agent_type">
					<option value=""></option>
					for _, t := range agentTypeOptions {
						<option value={ t }>{ t }</option>
					}
				</select>
			</label>
		</div>

		<div class="wv-form-section">
			<div class="wv-form-section-title">{ i18n.T("sec_routing") }</div>
			<label class="wv-field">
				<span class="wv-field-label">{ i18n.T("f_preferred_service") }</span>
				<select name="default_service" data-wv-service-select>
					<option value=""></option>
					for _, s := range services {
						<option value={ s.ID }>{ s.Name }</option>
					}
				</select>
			</label>
			<label class="wv-field">
				<span class="wv-field-label">{ i18n.T("f_model_override") }</span>
				<select name="default_model" data-wv-model-override data-wv-current="">
					<option value="">(서비스 기본 사용)</option>
				</select>
				<small class="hint">{ i18n.T("ph_model_default") }</small>
			</label>
		</div>

		<div class="wv-form-section">
			<div class="wv-form-section-title">{ i18n.T("sec_access") }</div>
			<label class="wv-field">
				<span class="wv-field-label">{ i18n.T("f_work_dir") }</span>
				<input name="work_dir" placeholder={ i18n.T("ph_workdir") }/>
				<small class="hint">{ i18n.T("hint_workdir_multi") }</small>
			</label>
			<label class="wv-field">
				<span class="wv-field-label">{ i18n.T("f_ip_whitelist") }</span>
				<input name="ip_whitelist" placeholder={ i18n.T("ph_ip_csv") }/>
				<small class="hint">{ i18n.T("hint_ip_open") }</small>
			</label>
			<label class="wv-field">
				<span class="wv-field-label">{ i18n.T("f_token") }</span>
				<input name="token" placeholder={ i18n.T("ph_token_auto") }/>
			</label>
		</div>

		<div class="wv-form-section">
			<div class="wv-form-section-title">{ i18n.T("sec_appearance") }</div>
			<label class="wv-field">
				<span class="wv-field-label">{ i18n.T("f_avatar") }</span>
				<div class="avatar-row">
					<div class="avatar-preview avatar-preview-empty" data-wv-avatar-preview>🤖</div>
					<input type="file" name="avatar" accept="image/*" data-wv-avatar-input/>
				</div>
				<small class="hint">{ i18n.T("hint_avatar") }</small>
			</label>
		</div>

		<div class="wv-form-actions">
			<button type="button" class="btn-secondary" data-wv-dismiss>{ i18n.T("act_cancel") }</button>
			<button type="submit">{ i18n.T("act_add") }</button>
		</div>
	</form>
}
