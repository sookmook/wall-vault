package mainview

import "fmt"

templ ServicesGrid(services []*ServiceVM) {
	<section>
		<h3>Services · { fmt.Sprint(len(services)) }</h3>
		<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:8px">
			for _, s := range services {
				@ServiceCard(s)
			}
		</div>
	</section>
}
