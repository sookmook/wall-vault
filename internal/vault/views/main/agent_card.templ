package mainview

import "github.com/sookmook/wall-vault/internal/i18n"

templ AgentCard(c *ClientVM) {
	<div class="card" data-wv-id={c.ID} hx-get={"/hx/clients/" + c.ID + "/edit"} hx-target="#slideover" hx-swap="outerHTML">
		<div class="card-head">
			<span class="drag-handle" title={ i18n.T("tip_drag_reorder") } draggable="true">⋮⋮</span>
			if c.Avatar != "" {
				<img src={ c.Avatar } alt={ c.Name } class="avatar"/>
			} else {
				<div class="avatar-fallback">🤖</div>
			}
			<div style="flex:1;min-width:0">
				<div class="card-row">
					<span class="card-title">{ c.Name }</span>
					<span class="chip">{ c.AgentType }</span>
				</div>
				<div class="card-meta">
					<span class={ "dot " + agentDotClass(c.Enabled, c.Online) }></span>
					<span>→ { c.PreferredService }</span>
					if c.ModelOverride != "" {
						<span class="chip chip-accent">{ c.ModelOverride }</span>
					} else if c.RemoteModel != "" {
						<span class="chip chip-accent">{ c.RemoteModel }</span>
					}
				</div>
				if c.Uptime != "" {
					<div class="card-meta"><span style="font-size:.88em">⏱ { c.Uptime }</span></div>
				}
			</div>
		</div>
	</div>
}

func agentDotClass(enabled, online bool) string {
	switch {
	case enabled && online:
		return "dot-ok"
	case enabled:
		return "dot-warn"
	default:
		return "dot-off"
	}
}
